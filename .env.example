# ─────────────────────────────────────────────────────────────────────────────
# AEGIS-G4 Environment Configuration Template
# Copy to .env and fill in your values. NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── ZoomEye API ───────────────────────────────────────────────────────────────
# Get your API key from: https://www.zoomeye.ai (Profile → API-KEY)
ZOOMEYE_API_KEY=your_zoomeye_api_key_here

# ── AbuseIPDB Threat Intelligence (v2 — free tier: 1000 req/day) ─────────────
# Register FREE at: https://www.abuseipdb.com/register
# Used to check if discovered IPs have a malicious reputation history
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# ── GitHub Code Search API (v2 — FREE, THE KEY DIFFERENTIATOR) ───────────────
# Traces live credential exposures BACK to their original source code in GitHub.
# This completes the full attack chain: code commit → live deployment
#
# HOW TO GET (2 minutes, completely free):
#   1. Go to: https://github.com/settings/tokens/new
#   2. Token name: "AEGIS-G4 Code Search"
#   3. Expiration: 90 days
#   4. Scopes: NONE needed (public repo search requires no scopes)
#   5. Click "Generate token" → copy the ghp_xxx value below
#
# Without token: 10 req/min (free, no account needed)
# With token:    30 req/min (3x more queries per run)
GITHUB_TOKEN=ghp_your_github_pat_here


# ── Ollama Local Model Names ───────────────────────────────────────────────────
# Ensure Ollama is running: `ollama serve`
# Pull models: `ollama pull gemma4:27b` etc.
OLLAMA_BASE_URL=http://localhost:11434/v1

COMMANDER_MODEL=gemma4:27b      # Main orchestrator (requires 32GB+ RAM or GPU)
SCOUT_MODEL=gemma4:4b           # ZoomEye dork generator (edge-optimized)
SENTINEL_MODEL=gemma4:4b        # Multimodal analyzer (vision-capable)
CRITIC_MODEL=gemma4:2b          # Safety reviewer (lightweight, fast)

# ── Demo / Honeypot Mode ──────────────────────────────────────────────────────
# Set DEMO_MODE=true to target only your controlled honeypot URLs
# NEVER set to false without understanding the legal implications
DEMO_MODE=true
HONEYPOT_URLS=http://localhost:8888,http://your-honeypot-domain.com

# ── Operational Limits ────────────────────────────────────────────────────────
REQUEST_TIMEOUT_SECONDS=15
MAX_TARGETS_PER_RUN=10          # Safety cap: max targets analyzed per swarm run
MAX_COMMANDER_STEPS=25          # Max reasoning steps for the Commander agent

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=aegis_g4.log
